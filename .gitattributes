# Cross-platform line-ending normalization (Windows + Linux)
* text=auto

# Python source
*.py   text eol=lf
*.pyi  text eol=lf

# Documentation
*.md   text eol=lf
*.rst  text eol=lf
*.txt  text eol=lf

# Config and structured data
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.conf  text eol=lf

# Shell scripts (Unix)
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Git metadata
.gitattributes text eol=lf
.gitignore     text eol=lf

# Binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.zip   binary
*.whl   binary
*.pyc   binary
*.pyo   binary
*.pyd   binary
*.so    binary
*.dll   binary
*.exe   binary

# Machine-generated lock files (exclude from GitHub language stats)
pixi.lock linguist-generated=true
